# Copie este arquivo para ".env" e preencha com suas credenciais.
# O ".env" é usado tanto para rodar o backend localmente (via python-dotenv)
# quanto pelo docker-compose (env_file do serviço tech-challenge-backend).

GEMINI_API_KEY=

# Opcional: quantos resultados por requisição recebem interpretação da LLM
# (limite para evitar excesso de chamadas). Padrão: 5.
MAX_LLM_INTERPRETATIONS=5
